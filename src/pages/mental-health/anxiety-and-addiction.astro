---
import { getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiloStyles from "../../components/SiloStyles.astro";
import MentalHealthPage from "../../components/MentalHealthPage.astro";

const m = (await getEntry("mentalHealth", "anxiety-and-addiction"))!.data;
const facility = (await getEntry("facility", "golden-grove-recovery"))!.data;

const title = `Anxiety and Addiction Treatment in ${facility.city}, ${facility.stateCode} | Golden Grove Recovery`;
const description = `Integrated treatment for co-occurring anxiety disorders and substance use — including non-addictive medication options for patients with active SUD. Kentucky Medicaid covered.`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "MedicalWebPage",
    name: title,
    description,
    about: { "@type": "MedicalCondition", name: "Generalized Anxiety Disorder", code: { "@type": "MedicalCode", codeValue: "F41.1", codingSystem: "ICD-10" } },
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiloStyles />
  <MentalHealthPage slug="anxiety-and-addiction" trail={[
    { label: "Home", href: "/" },
    { label: "Mental Health", href: "/mental-health" },
    { label: m.name },
  ]} />
</BaseLayout>
