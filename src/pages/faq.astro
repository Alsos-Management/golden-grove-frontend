---
import BaseLayout from "../layouts/BaseLayout.astro";
import FAQPage from "../react-pages/FAQ.jsx";
import { GlobalStyles } from "../components/shared.jsx";
import { FAQS } from "../data.js";

const title = "Frequently Asked Questions | Golden Grove Recovery";
const description = "Common questions about admissions, treatment length, medication-assisted treatment, insurance, and what to expect at Golden Grove Recovery.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: FAQS.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <GlobalStyles client:load />
  <FAQPage client:load />
</BaseLayout>
