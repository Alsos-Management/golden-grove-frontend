---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Cta from "../../components/Cta.astro";
import SiloStyles from "../../components/SiloStyles.astro";
import InsuranceDisclaimer from "../../components/InsuranceDisclaimer.astro";

export async function getStaticPaths() {
  const mcos = await getCollection("mcos");
  return mcos.map((entry) => ({
    params: { mco: entry.data.slug },
    props: { mco: entry },
  }));
}

const { mco } = Astro.props as { mco: Awaited<ReturnType<typeof getCollection<"mcos">>>[number] };
const m = mco.data;
const facility = (await getEntry("facility", "golden-grove-recovery"))!.data;
const allMcos = (await getCollection("mcos"))
  .filter((e) => e.data.slug !== m.slug)
  .sort((a, b) => a.data.name.localeCompare(b.data.name));

const matLabels: Record<string, string> = {
  suboxone: "Suboxone",
  subutex: "Subutex",
  methadone: "Methadone",
  vivitrol: "Vivitrol",
  naltrexone: "Oral Naltrexone",
  acamprosate: "Acamprosate",
  disulfiram: "Disulfiram",
};

const asamLabels: Record<string, string> = {
  "0.5": "Recovery Housing (ASAM 0.5)",
  "1": "Outpatient (ASAM 1)",
  "2.1": "Intensive Outpatient (ASAM 2.1)",
  "2.5": "Partial Hospitalization (ASAM 2.5)",
  "3.1": "Clinically Managed Low-Intensity Residential (ASAM 3.1)",
  "3.3": "Clinically Managed Population-Specific High-Intensity Residential (ASAM 3.3)",
  "3.5": "Clinically Managed High-Intensity Residential (ASAM 3.5)",
  "3.7": "Medically Monitored Inpatient Withdrawal Management (ASAM 3.7)",
  "4": "Medically Managed Intensive Inpatient (ASAM 4)",
};

const title = `${m.name} drug & alcohol rehab coverage in ${facility.state} | Golden Grove Recovery`;
const description = `${m.shortName} covers detox, residential, PHP, IOP, outpatient, and MAT for substance use disorder. Verify your ${m.shortName} benefits with Golden Grove Recovery in Louisville, KY.`;

const faqs = [
  {
    q: `Does ${m.shortName} cover residential addiction treatment?`,
    a: `Yes. ${m.shortName} covers residential SUD treatment (ASAM 3.1, 3.3, 3.5) based on medical-necessity determination using ASAM criteria. Prior authorization with concurrent review is typical.`,
  },
  {
    q: `Does ${m.shortName} cover Suboxone or methadone?`,
    a: `${m.shortName} covers ${m.matCovered.map((x) => matLabels[x] ?? x).join(", ")} as part of its MAT benefit. Methadone is delivered through licensed opioid treatment programs (OTPs).`,
  },
  {
    q: `Will ${m.shortName} cover medical detox?`,
    a: `Yes. ${m.shortName} covers medically supervised withdrawal management at ASAM 3.7 and 4. Authorization is typically obtained urgently at admission based on clinical presentation.`,
  },
  {
    q: `What does prior authorization look like with ${m.shortName}?`,
    a: m.priorAuthNotes ?? `${m.shortName} typically applies ASAM criteria for medical-necessity determinations. Our admissions team handles authorization on your behalf — call or use the verify-insurance form to start.`,
  },
  {
    q: `Is Golden Grove Recovery in-network with ${m.shortName}?`,
    a: facility.insurance.disclaimerPreOpening,
  },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "MedicalWebPage",
    name: title,
    description,
    about: {
      "@type": "HealthInsurancePlan",
      name: m.name,
      url: m.url,
      healthPlanCoverageType: "Medicaid",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  },
];

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (p: string) => `${BASE}${p}`;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiloStyles />
  <Breadcrumbs trail={[
    { label: "Home", href: "/" },
    { label: "Medicaid", href: "/medicaid" },
    { label: m.shortName },
  ]} />

  <article class="silo-page">
    <div class="silo-eyebrow">Kentucky Medicaid · {m.shortName}</div>
    <h1>{m.name} drug &amp; alcohol rehab coverage in {facility.state}</h1>
    <p class="silo-lede">{m.description}</p>

    <InsuranceDisclaimer variant="pre-opening" />

    <h2>What's covered for substance use disorder treatment</h2>
    <ul>
      {m.coverageHighlights.map((item) => <li>{item}</li>)}
    </ul>

    <h2>ASAM levels of care covered by {m.shortName}</h2>
    <div class="silo-table-wrap">
      <table class="silo-table">
        <thead>
          <tr><th>ASAM Level</th><th>Description</th></tr>
        </thead>
        <tbody>
          {m.levelsOfCareCovered.map((level) => (
            <tr>
              <td><strong>{level}</strong></td>
              <td>{asamLabels[level] ?? level}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h2>Medication-Assisted Treatment (MAT) covered by {m.shortName}</h2>
    <p>
      {m.shortName} covers the following FDA-approved MAT medications for opioid use disorder
      and, where applicable, alcohol use disorder:
    </p>
    <div>
      {m.matCovered.map((med) => <span class="silo-pill">{matLabels[med] ?? med}</span>)}
    </div>
    <p style="margin-top: 16px;">
      Read more about how Medicaid covers <a href={link("/medicaid/medicaid-mat-coverage")}>MAT</a>,
      including specific authorization requirements and pharmacy benefits.
    </p>

    {m.priorAuthNotes && (
      <>
        <h2>Prior authorization notes</h2>
        <p>{m.priorAuthNotes}</p>
      </>
    )}

    {m.memberBenefitsNote && (
      <>
        <h2>Member benefits that apply to SUD treatment</h2>
        <p>{m.memberBenefitsNote}</p>
        {m.url && (
          <p>
            More on {m.shortName}'s benefits at <a href={m.url} target="_blank" rel="noopener noreferrer">{m.url}</a>.
          </p>
        )}
      </>
    )}

    <h2>How to verify your {m.shortName} coverage</h2>
    <p>
      Our admissions team handles benefits verification on your behalf. Have your member ID handy
      when you call, and we'll confirm what's covered, what authorization (if any) is required,
      and what your next step looks like.
    </p>

    <Cta heading={`Verify your ${m.shortName} coverage`}
         subhead={`Call admissions or send a quick verification request — we'll confirm what your ${m.shortName} plan covers.`} />

    <h2>Frequently asked questions</h2>
    <div class="silo-faq">
      {faqs.map((f) => (
        <details>
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>

    <h2>Other Kentucky Medicaid plans</h2>
    <ul>
      {allMcos.map((other) => (
        <li>
          <a href={link(`/medicaid/${other.data.slug}`)}>{other.data.name}</a>
        </li>
      ))}
    </ul>
    <p>
      Or return to the <a href={link("/medicaid")}>Kentucky Medicaid coverage hub</a>.
    </p>
  </article>
</BaseLayout>
