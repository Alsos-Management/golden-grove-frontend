---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Cta from "../../components/Cta.astro";
import SiloStyles from "../../components/SiloStyles.astro";
import InsuranceDisclaimer from "../../components/InsuranceDisclaimer.astro";

const detox = (await getEntry("levelsOfCare", "medical-detox"))!.data;
const mcos = (await getCollection("mcos")).sort((a, b) => a.data.name.localeCompare(b.data.name));

const title = "Does Kentucky Medicaid Cover Detox? | Golden Grove Recovery";
const description = "Kentucky Medicaid covers medically supervised detox (ASAM 3.7 and 4) for alcohol, opioids, benzodiazepines, and other substances. Coverage details by MCO.";

const faqs = [
  { q: "Does Kentucky Medicaid cover medical detox?", a: "Yes. All six Kentucky Medicaid MCOs cover medical detox at ASAM 3.7 and 4 based on medical-necessity determination. Authorization is typically obtained urgently at admission." },
  { q: "Will I need prior authorization for detox?", a: "Detox is usually authorized urgently based on clinical presentation, not pre-authorized days in advance. Our admissions team handles the authorization process at admission." },
  { q: "How long does Medicaid cover detox?", a: "Coverage continues as long as the level of care is medically necessary. Medical detox typically runs 3–7 days; benzodiazepine taper may extend longer based on the taper schedule." },
  { q: "Does Kentucky Medicaid cover MAT during detox?", a: "Yes. Buprenorphine (Suboxone or Subutex) induction is commonly started during detox for opioid use disorder, and is a covered Medicaid pharmacy benefit." },
];

const jsonLd = [
  { "@context": "https://schema.org", "@type": "MedicalWebPage", name: title, description },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
  },
];

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (p: string) => `${BASE}${p}`;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiloStyles />
  <Breadcrumbs trail={[
    { label: "Home", href: "/" },
    { label: "Medicaid", href: "/medicaid" },
    { label: "Detox Coverage" },
  ]} />

  <article class="silo-page">
    <div class="silo-eyebrow">Kentucky Medicaid · Coverage Detail</div>
    <h1>Does Kentucky Medicaid cover medical detox?</h1>
    <p class="silo-lede">
      <strong>Yes.</strong> All six Kentucky Medicaid managed care organizations cover medically
      supervised withdrawal management (detox) at ASAM levels 3.7 and 4 when medically necessary.
      For alcohol and benzodiazepine withdrawal, which can be life-threatening, medical detox is
      considered the standard of care — and Medicaid authorization is typically obtained urgently
      based on clinical presentation rather than pre-authorized days in advance.
    </p>

    <InsuranceDisclaimer variant="medicaid" />

    <h2>What detox covers</h2>
    <p>{detox.description}</p>

    <h2>Who benefits from detox</h2>
    <ul>
      {detox.whoBenefits.map((b) => <li>{b}</li>)}
    </ul>

    <h2>What a typical detox stay looks like</h2>
    <p>{detox.typicalDay}</p>
    <p><strong>Typical duration:</strong> {detox.typicalDuration}.</p>

    <h2>How Kentucky's 1115 waiver applies to detox</h2>
    <p>{detox.imdExclusionNote}</p>

    <h2>Detox coverage by MCO</h2>
    <p>
      Each Kentucky Medicaid MCO covers detox slightly differently in terms of authorization workflow.
      Pick your plan for specifics:
    </p>
    <ul>
      {mcos.map((m) => (
        <li><a href={link(`/medicaid/${m.data.slug}`)}>{m.data.name}</a></li>
      ))}
    </ul>

    <h2>What happens after detox</h2>
    <p>
      Detox is the first step, not the full treatment. After medical stabilization, most patients step
      down to <a href={link("/medicaid/medicaid-residential-coverage")}>residential treatment</a> or
      directly to <a href={link("/medicaid/medicaid-php-iop-coverage")}>PHP or IOP</a> depending on
      severity, support system, and clinical recommendation. For opioid use disorder,
      <a href={link("/medicaid/medicaid-mat-coverage")}>MAT</a> typically continues from detox
      through the entire treatment continuum.
    </p>

    <Cta heading="Verify your Kentucky Medicaid detox coverage"
         subhead="If you're in withdrawal or about to be, call us — admissions handles urgent verification and authorization." />

    <h2>Frequently asked questions</h2>
    <div class="silo-faq">
      {faqs.map((f) => (
        <details>
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </article>
</BaseLayout>
