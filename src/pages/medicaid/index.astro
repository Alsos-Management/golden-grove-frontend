---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Cta from "../../components/Cta.astro";
import SiloStyles from "../../components/SiloStyles.astro";
import InsuranceDisclaimer from "../../components/InsuranceDisclaimer.astro";

const facility = (await getEntry("facility", "golden-grove-recovery"))!.data;
const mcos = (await getCollection("mcos")).sort((a, b) => a.data.name.localeCompare(b.data.name));

const title = "Medicaid Drug & Alcohol Rehab in Louisville, KY | Golden Grove Recovery";
const description = "Kentucky Medicaid covers detox, residential, PHP, IOP, outpatient, and MAT. Golden Grove Recovery serves Louisville, KY — verify your Medicaid plan.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  name: title,
  description,
  about: {
    "@type": "MedicalAudience",
    audienceType: "Kentucky Medicaid members with substance use disorder",
    geographicArea: {
      "@type": "AdministrativeArea",
      name: "Kentucky",
    },
  },
  mainContentOfPage: {
    "@type": "WebPageElement",
    cssSelector: "main",
  },
};

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (p: string) => `${BASE}${p}`;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiloStyles />
  <Breadcrumbs trail={[
    { label: "Home", href: "/" },
    { label: "Medicaid Coverage" },
  ]} />

  <article class="silo-page">
    <div class="silo-eyebrow">Medicaid Coverage</div>
    <h1>Medicaid drug &amp; alcohol rehab in Louisville, KY</h1>
    <p class="silo-lede">
      Golden Grove Recovery is preparing to serve {facility.city}, {facility.state} with addiction
      treatment that's covered by Kentucky Medicaid managed care. Detox, residential, PHP, IOP,
      outpatient, and medication-assisted treatment are all covered Medicaid benefits when
      medically necessary.
    </p>

    <InsuranceDisclaimer variant="pre-opening" />

    <h2>Kentucky Medicaid Managed Care Organizations (MCOs)</h2>
    <p>
      Kentucky Medicaid is administered by six managed care organizations. Pick your plan to see
      what's covered for substance use disorder treatment, what prior authorization typically
      involves, and how MAT (Suboxone, methadone, Vivitrol) is handled under your plan.
    </p>

    <div class="silo-grid">
      {mcos.map((mco) => (
        <a class="silo-card mco-card" href={link(`/medicaid/${mco.data.slug}`)}>
          <div class="silo-eyebrow">Kentucky Medicaid</div>
          <h3>{mco.data.name}</h3>
          <p>{mco.data.description.slice(0, 180)}{mco.data.description.length > 180 ? "…" : ""}</p>
          <span class="cta-arrow">View {mco.data.shortName} coverage →</span>
        </a>
      ))}
    </div>

    <h2>What Kentucky Medicaid covers for SUD treatment</h2>
    <p>
      Every Kentucky Medicaid MCO covers the full ASAM continuum for substance use disorder when
      medically necessary. Specific authorization requirements vary by plan and level of care.
    </p>
    <ul>
      <li><a href={link("/medicaid/medicaid-detox-coverage")}>Medical detox (ASAM 3.7 / 4)</a> — life-threatening alcohol or benzodiazepine withdrawal handled in supervised settings</li>
      <li><a href={link("/medicaid/medicaid-residential-coverage")}>Residential / inpatient (ASAM 3.1, 3.3, 3.5)</a> — Kentucky's 1115 waiver allows full Medicaid coverage of residential SUD treatment</li>
      <li><a href={link("/medicaid/medicaid-php-iop-coverage")}>Partial Hospitalization &amp; Intensive Outpatient (ASAM 2.5, 2.1)</a> — structured step-down or step-up care</li>
      <li><a href={link("/medicaid/medicaid-mat-coverage")}>Medication-Assisted Treatment</a> — Suboxone, Subutex, methadone, Vivitrol, and naltrexone are covered MAT options</li>
      <li><a href={link("/medicaid/medicaid-outpatient-coverage")}>Outpatient SUD services</a> — therapy, group counseling, MAT management, and continuing care</li>
    </ul>

    <h2>Background &amp; eligibility</h2>
    <ul>
      <li><a href={link("/medicaid/kentucky-medicaid-coverage")}>How Kentucky Medicaid covers SUD treatment</a> — pillar overview</li>
      <li><a href={link("/medicaid/how-to-apply-for-medicaid-kentucky")}>How to apply for Kentucky Medicaid</a></li>
      <li><a href={link("/medicaid/no-insurance-options")}>What if I don't have insurance?</a> — sliding scale, state-funded, and charity options</li>
    </ul>

    <Cta heading="Verify your Kentucky Medicaid coverage"
         subhead="Tell us your MCO and we'll confirm your benefits before admission. No obligation, no judgment." />
  </article>
</BaseLayout>

<style>
  .mco-card {
    display: block;
    text-decoration: none !important;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .mco-card:hover {
    border-color: #8C6934;
    box-shadow: 0 6px 18px rgba(70, 31, 1, 0.06);
    transform: translateY(-2px);
  }
  .mco-card h3 { margin: 4px 0 8px; }
  .mco-card p { font-size: 14px; color: #444; margin: 0 0 12px; }
  .cta-arrow { color: #8C6934; font-weight: 700; font-size: 13px; }
</style>
