---
import { getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import SiloStyles from "../../components/SiloStyles.astro";
import LocationPage from "../../components/LocationPage.astro";

const loc = (await getEntry("locations", "st-matthews"))!.data;
const facility = (await getEntry("facility", "golden-grove-recovery"))!.data;

const title = `Drug & Alcohol Rehab Serving St. Matthews, KY | Golden Grove Recovery`;
const description = `Kentucky Medicaid-covered addiction treatment for St. Matthews residents. Detox, residential, PHP, IOP, and MAT at Golden Grove Recovery in nearby Louisville, KY.`;

const jsonLd = [
  { "@context": "https://schema.org", "@type": "MedicalWebPage", name: title, description },
  {
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "MedicalBusiness", "MedicalClinic"],
    name: facility.name,
    url: new URL(Astro.url.pathname, Astro.site).toString(),
    telephone: facility.phone,
    address: {
      "@type": "PostalAddress",
      streetAddress: facility.address.street,
      addressLocality: facility.address.city,
      addressRegion: facility.address.state,
      postalCode: facility.address.postalCode,
      addressCountry: facility.address.country,
    },
    geo: { "@type": "GeoCoordinates", latitude: facility.geo.lat, longitude: facility.geo.lng },
    areaServed: { "@type": "City", name: loc.name },
    medicalSpecialty: ["Addiction Medicine", "Psychiatry"],
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiloStyles />
  <Breadcrumbs trail={[
    { label: "Home", href: "/" },
    { label: "Service Areas", href: "/locations" },
    { label: loc.name },
  ]} />
  <LocationPage slug="st-matthews" />
</BaseLayout>
