---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Cta from "../../components/Cta.astro";
import SiloStyles from "../../components/SiloStyles.astro";

const facility = (await getEntry("facility", "golden-grove-recovery"))!.data;
const locations = (await getCollection("locations")).sort((a, b) => a.data.name.localeCompare(b.data.name));

const title = `Service Areas in Greater ${facility.city}, ${facility.stateCode} | Golden Grove Recovery`;
const description = `Golden Grove Recovery serves Louisville and Greater Jefferson County, KY — including Jeffersontown and St. Matthews — with Kentucky Medicaid-covered addiction treatment.`;

const jsonLd = { "@context": "https://schema.org", "@type": "MedicalWebPage", name: title, description };

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (p: string) => `${BASE}${p}`;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiloStyles />
  <Breadcrumbs trail={[
    { label: "Home", href: "/" },
    { label: "Service Areas" },
  ]} />

  <article class="silo-page">
    <div class="silo-eyebrow">Service Areas</div>
    <h1>Areas we serve</h1>
    <p class="silo-lede">
      Golden Grove Recovery serves Greater {facility.city} and Jefferson County, {facility.stateCode}.
      Our facility is located at {facility.address.street}, {facility.address.city}, {facility.address.state} {facility.address.postalCode}.
    </p>

    <h2>Locations we serve</h2>
    <ul>
      {locations.map((l) => (
        <li>
          <a href={link(`/locations/${l.data.slug}`)}>{l.data.name}, {l.data.stateCode}</a>
          {l.data.distanceFromFacility && <span style="color: #6B6B6B; font-size: 13px;"> — {l.data.distanceFromFacility}</span>}
        </li>
      ))}
    </ul>

    <h2>Indiana residents</h2>
    <p>
      Indiana Medicaid does not cover treatment at Kentucky facilities. If you're an Indiana resident
      seeking treatment, our sister facility — <strong>Jasper Grove Recovery</strong> in Indiana —
      may be a better fit. Our admissions team can help route you appropriately.
    </p>

    <Cta heading="Verify your coverage and start treatment" />
  </article>
</BaseLayout>
