---
import { getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiloHero from "../../components/SiloHero.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Cta from "../../components/Cta.astro";
import SiloStyles from "../../components/SiloStyles.astro";

const facility = (await getEntry("facility", "golden-grove-recovery"))!.data;

const title = `Accreditations & Licensing | Golden Grove Recovery`;
const description = `Golden Grove Recovery's clinical accreditations, state licensing, and quality assurance — pursued ahead of opening to ensure patients receive treatment at industry-standard quality.`;

const jsonLd = { "@context": "https://schema.org", "@type": "AboutPage", name: title, description };

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (p: string) => `${BASE}${p}`;

const pursuing = [
  { eyebrow: "State licensing", title: "Kentucky DBHDID", body: "State SUD treatment facility license issued by the Kentucky Department for Behavioral Health, Developmental and Intellectual Disabilities." },
  { eyebrow: "Third-party", title: "The Joint Commission", body: "Behavioral Health Care accreditation — a leading independent quality standard." },
  { eyebrow: "Third-party", title: "CARF International", body: "Commission on Accreditation of Rehabilitation Facilities accreditation for SUD programs." },
  { eyebrow: "Marketing", title: "LegitScript Certified Treatment", body: "Third-party verification for ethical advertising and operations." },
  { eyebrow: "Network", title: "Kentucky Recovery Network", body: "Participation in Kentucky's recovery support infrastructure." },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiloStyles />
  <div class="silo-body">
    <SiloHero
      eyebrow="About Golden Grove · Accreditations"
      title="Accreditations & licensing"
      lede="Quality in addiction treatment is measurable — through state licensing, third-party accreditation, and outcomes reporting. Golden Grove Recovery is preparing to open with the accreditations that Kentucky Medicaid and commercial insurers require, plus voluntary accreditations that reflect industry-leading standards."
    />
    <Breadcrumbs trail={[
      { label: "Home", href: "/" },
      { label: "About", href: "/about" },
      { label: "Accreditations" },
    ]} />

    {facility.accreditations.length === 0 ? (
      <>
        <section class="silo-section is-light">
          <div class="silo-container silo-narrow">
            <div class="silo-section-label">Status</div>
            <h2>Pre-opening</h2>
            <p>Golden Grove Recovery is in pre-opening setup. Accreditations and state licensing are being pursued in parallel with facility readiness. We will publish each accreditation here as it is awarded.</p>
          </div>
        </section>

        <section class="silo-section is-dust">
          <div class="silo-container">
            <div class="silo-section-label">Roadmap</div>
            <h2>Accreditations we are pursuing</h2>
            <div class="silo-grid">
              {pursuing.map((a) => (
                <div class="silo-card">
                  <div class="silo-card-eyebrow">{a.eyebrow}</div>
                  <h3>{a.title}</h3>
                  <p>{a.body}</p>
                </div>
              ))}
            </div>
          </div>
        </section>

        <section class="silo-section is-light">
          <div class="silo-container silo-narrow">
            <div class="silo-section-label">Why this matters</div>
            <h2>Accreditation is a quality signal</h2>
            <p>Accreditation isn't paperwork — it's a third-party validation that a treatment facility meets industry standards for clinical quality, patient safety, ethical marketing, and outcomes reporting. Kentucky Medicaid plans and commercial carriers require state licensing and typically also require Joint Commission or CARF accreditation for in-network status. Patients should expect any facility they consider to be accredited and licensed.</p>
          </div>
        </section>
      </>
    ) : (
      <section class="silo-section is-light">
        <div class="silo-container">
          <div class="silo-section-label">Current accreditations</div>
          <h2>Accredited and licensed</h2>
          <div class="silo-grid">
            {facility.accreditations.map((a) => (
              <div class="silo-card">
                <div class="silo-card-eyebrow">{a.abbreviation ?? "Accreditation"}</div>
                <h3>{a.name}</h3>
                {a.licenseNumber && <p>License {a.licenseNumber}</p>}
                {a.url && <p><a href={a.url} target="_blank" rel="noopener noreferrer">Verify accreditation</a></p>}
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <Cta heading="Questions about our accreditations?"
         subhead="Call admissions for current status on any specific accreditation or licensing question." />
  </div>
</BaseLayout>
