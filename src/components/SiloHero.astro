---
import { getEntry } from "astro:content";

export interface Props {
  eyebrow: string;
  title: string;
  lede?: string;
  variant?: "default" | "compact";
}

const { eyebrow, title, lede, variant = "default" } = Astro.props as Props;
const facility = (await getEntry("facility", "golden-grove-recovery"))!.data;
---

<section class:list={["silo-hero", `is-${variant}`]}>
  <div class="silo-hero-bg-pattern" aria-hidden="true"></div>
  <div class="silo-hero-inner">
    <div class="silo-hero-eyebrow">{eyebrow}</div>
    <h1 class="silo-hero-title">{title}</h1>
    {lede && <p class="silo-hero-lede">{lede}</p>}
    <div class="silo-hero-ctas">
      <a href={`tel:${facility.phoneTel}`} class="gg-btn gg-btn-light">
        Call {facility.phone}
      </a>
      <a
        href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/admissions`}
        class="gg-btn gg-btn-secondary"
      >
        Contact Admissions
      </a>
    </div>
  </div>
</section>

<style>
  .silo-hero {
    position: relative;
    color: #FFFFFF;
    background: linear-gradient(165deg, #2E1400 0%, #461F01 40%, #8C6934 100%);
    padding: 130px 24px 70px;
    overflow: hidden;
    margin-top: 0;
  }
  .silo-hero.is-compact {
    padding: 110px 24px 50px;
  }
  .silo-hero-bg-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    background-image: radial-gradient(circle, white 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }
  .silo-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    text-align: left;
  }
  .silo-hero-eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #F2D17D;
    margin-bottom: 16px;
    padding: 4px 12px;
    border-radius: 999px;
    background: rgba(242, 209, 125, 0.12);
    border: 1px solid rgba(242, 209, 125, 0.25);
  }
  .silo-hero-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin: 0 0 18px;
    color: #FFFFFF;
    max-width: 760px;
  }
  .silo-hero-lede {
    font-size: clamp(15px, 1.5vw, 18px);
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.65;
    max-width: 640px;
    margin: 0 0 32px;
  }
  .silo-hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  @media (max-width: 600px) {
    .silo-hero { padding: 100px 16px 44px; }
    .silo-hero-ctas { flex-direction: column; align-items: stretch; }
    .silo-hero-ctas .gg-btn { width: 100%; }
  }
</style>
